{
    "name": "ericgansa/filter-manager-bundle",
    "description": "Symfony bundle for dynamic filtering, pagination and user-scoped queries with Doctrine ORM",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Eric Gansa",
            "email": "ericgansa02@gmail.com",
            "role": "Developer"
        }
    ],
    "keywords": ["symfony", "bundle", "filter", "pagination", "doctrine", "orm", "query"],
    "require": {
        "php": ">=8.2",
        "doctrine/orm": "^2.15 || ^3.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "require-dev": {
        "doctrine/doctrine-bundle": "^2.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/security-bundle": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "suggest": {
        "symfony/security-bundle": "Required to enable user-scoped filtering (mine/others scopes)"
    },
    "autoload": {
        "psr-4": {
            "EricGansa\\FilterManagerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EricGansa\\FilterManagerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "symfony": {
            "require": "^6.4 || ^7.0"
        }
    }
}
